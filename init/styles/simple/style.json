{
  "version": 8,
  "name": "Offline Belarus – clean OSM style + building labels",
  "glyphs": "/tiles/fonts/{fontstack}/{range}.pbf",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "pmtiles:///tiles/belarus.pmtiles"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f2f2f2"
      }
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "paint": {
        "fill-color": "#dcefd5",
        "fill-opacity": 0.55
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "paint": {
        "fill-color": "#ebe8dc",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": {
        "fill-color": "#a8cfee"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#88b8e8",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          8,
          0.4,
          14,
          1.8
        ]
      }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#ded8d0",
        "fill-opacity": 0.75
      }
    },
    {
      "id": "house-numbers",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "housenumber",
      "minzoom": 14,
      "layout": {
        "text-field": [
          "get",
          "housenumber"
        ],
        "text-font": [
          "Roboto Regular"
        ],
        "text-size": 7,
        "text-anchor": "center",
        "text-allow-overlap": false
      },
      "paint": {
        "text-color": "#666666",
        "text-halo-color": "#ffffff",
        "text-halo-width": 0.8
      }
    },
    {
      "id": "roads-major-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 7,
      "filter": [
        "match",
        [
          "get",
          "class"
        ],
        [
          "motorway",
          "trunk",
          "primary"
        ],
        true,
        false
      ],
      "paint": {
        "line-color": "#c8c3bd",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          7,
          1.4,
          12,
          4.2,
          14,
          9.5
        ]
      }
    },
    {
      "id": "roads-major",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 7,
      "filter": [
        "match",
        [
          "get",
          "class"
        ],
        [
          "motorway",
          "trunk",
          "primary"
        ],
        true,
        false
      ],
      "paint": {
        "line-color": "#ffffff",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          7,
          0.9,
          12,
          3.2,
          14,
          7.5
        ]
      }
    },
    {
      "id": "roads-medium-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 9,
      "filter": [
        "match",
        [
          "get",
          "class"
        ],
        [
          "secondary",
          "tertiary"
        ],
        true,
        false
      ],
      "paint": {
        "line-color": "#d0cbc6",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          9,
          0.9,
          14,
          5.0
        ]
      }
    },
    {
      "id": "roads-medium",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 9,
      "filter": [
        "match",
        [
          "get",
          "class"
        ],
        [
          "secondary",
          "tertiary"
        ],
        true,
        false
      ],
      "paint": {
        "line-color": "#ffffff",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          9,
          0.6,
          14,
          4.0
        ]
      }
    },
    {
      "id": "roads-minor-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 12,
      "filter": [
        "match",
        [
          "get",
          "class"
        ],
        [
          "residential",
          "service",
          "track",
          "path",
          "unclassified",
          "living_street"
        ],
        true,
        false
      ],
      "paint": {
        "line-color": "#d6d3cf",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          12,
          0.6,
          14,
          2.2
        ]
      }
    },
    {
      "id": "roads-minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 12,
      "filter": [
        "match",
        [
          "get",
          "class"
        ],
        [
          "residential",
          "service",
          "track",
          "path",
          "unclassified",
          "living_street"
        ],
        true,
        false
      ],
      "paint": {
        "line-color": "#f8f8f8",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          12,
          0.4,
          14,
          1.6
        ]
      }
    },
    {
      "id": "road-labels",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "minzoom": 13,
      "layout": {
        "symbol-placement": "line",
        "text-field": [
          "coalesce",
          [
            "get",
            "name:ru"
          ],
          [
            "get",
            "name"
          ],
          [
            "get",
            "name:latin"
          ],
          [
            "get",
            "ref"
          ]
        ],
        "text-font": [
          "Roboto Regular"
        ],
        "text-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          13,
          9,
          14,
          11
        ],
        "text-max-width": 8,
        "symbol-spacing": 300
      },
      "paint": {
        "text-color": "#555555",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.0
      }
    },
    {
      "id": "poi-labels",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "poi",
      "minzoom": 14,
      "filter": [
        "any",
        [
          "has",
          "name"
        ],
        [
          "has",
          "name:ru"
        ],
        [
          "has",
          "name:latin"
        ]
      ],
      "layout": {
        "text-field": [
          "coalesce",
          [
            "get",
            "name:ru"
          ],
          [
            "get",
            "name"
          ],
          [
            "get",
            "name:latin"
          ]
        ],
        "text-font": [
          "Roboto Regular"
        ],
        "text-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          14,
          10,
          16,
          12
        ],
        "text-max-width": 12,
        "text-anchor": "top",
        "text-offset": [
          0,
          0.6
        ],
        "text-allow-overlap": false,
        "text-ignore-placement": false,
        "symbol-sort-key": [
          "case",
          [
            "in",
            [
              "get",
              "class"
            ],
            [
              "literal",
              [
                "hospital",
                "school",
                "university",
                "police",
                "fire_station"
              ]
            ]
          ],
          300,
          [
            "in",
            [
              "get",
              "class"
            ],
            [
              "literal",
              [
                "station",
                "bus",
                "railway"
              ]
            ]
          ],
          220,
          [
            "in",
            [
              "get",
              "class"
            ],
            [
              "literal",
              [
                "industrial",
                "office"
              ]
            ]
          ],
          180,
          100
        ]
      },
      "paint": {
        "text-color": "#2f2f2f",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.4
      }
    },
    {
      "id": "place-labels",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 6,
      "layout": {
        "text-field": [
          "coalesce",
          [
            "get",
            "name:ru"
          ],
          [
            "get",
            "name"
          ],
          [
            "get",
            "name:latin"
          ]
        ],
        "text-font": [
          "Roboto Regular"
        ],
        "text-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          6,
          10,
          10,
          14
        ]
      },
      "paint": {
        "text-color": "#333333",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.4
      }
    }
  ]
}
