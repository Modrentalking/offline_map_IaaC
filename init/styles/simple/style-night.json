{
    "version": 8,
    "name": "Offline Belarus – night mode",
    "glyphs": "http://192.168.100.252:8080/fonts/{fontstack}/{range}.pbf",
  
    "sources": {
      "openmaptiles": {
        "type": "vector",
        "tiles": ["http://192.168.100.252:8080/data/belarus/{z}/{x}/{y}.pbf"],
        "minzoom": 6,
        "maxzoom": 14
      }
    },
  
    "layers": [
      { "id": "background", "type": "background",
        "paint": { "background-color": "#0f1419" } },
  
      { "id": "landcover", "type": "fill", "source": "openmaptiles",
        "source-layer": "landcover",
        "paint": { "fill-color": "#182028", "fill-opacity": 0.8 }
      },
  
      { "id": "landuse", "type": "fill", "source": "openmaptiles",
        "source-layer": "landuse",
        "paint": { "fill-color": "#1b232b", "fill-opacity": 0.8 }
      },
  
      { "id": "water", "type": "fill", "source": "openmaptiles",
        "source-layer": "water",
        "paint": { "fill-color": "#0b2a3f" }
      },
  
      { "id": "waterway", "type": "line", "source": "openmaptiles",
        "source-layer": "waterway",
        "paint": {
          "line-color": "#144d73",
          "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.4, 14, 1.8]
        }
      },
  
      { "id": "buildings", "type": "fill", "source": "openmaptiles",
        "source-layer": "building",
        "minzoom": 13,
        "paint": { "fill-color": "#2a3138", "fill-opacity": 0.85 }
      },
  
      {
        "id": "house-numbers",
        "type": "symbol",
        "source": "openmaptiles",
        "source-layer": "housenumber",
        "minzoom": 14,
        "layout": {
          "text-field": ["get", "housenumber"],
          "text-font": ["Roboto Regular"],
          "text-size": 7
        },
        "paint": {
          "text-color": "#cfd6dc",
          "text-halo-color": "#0f1419",
          "text-halo-width": 1
        }
      },
  
      {
        "id": "roads",
        "type": "line",
        "source": "openmaptiles",
        "source-layer": "transportation",
        "minzoom": 7,
        "paint": {
          "line-color": "#e0e6eb",
          "line-width": ["interpolate", ["linear"], ["zoom"], 7, 0.6, 14, 4.5]
        }
      },
  
      {
        "id": "road-labels",
        "type": "symbol",
        "source": "openmaptiles",
        "source-layer": "transportation_name",
        "minzoom": 13,
        "layout": {
          "symbol-placement": "line",
          "text-field": ["coalesce",
            ["get", "name:ru"],
            ["get", "name"],
            ["get", "name:latin"]
          ],
          "text-font": ["Roboto Regular"],
          "text-size": 10
        },
        "paint": {
          "text-color": "#d8dde2",
          "text-halo-color": "#0f1419",
          "text-halo-width": 1.2
        }
      },
  
      {
        "id": "poi-labels",
        "type": "symbol",
        "source": "openmaptiles",
        "source-layer": "poi",
        "minzoom": 14,
        "layout": {
          "text-field": ["coalesce",
            ["get", "name:ru"],
            ["get", "name"],
            ["get", "name:latin"]
          ],
          "text-font": ["Roboto Regular"],
          "text-size": 10,
          "text-offset": [0, 0.6]
        },
        "paint": {
          "text-color": "#f0f4f8",
          "text-halo-color": "#0f1419",
          "text-halo-width": 1.4
        }
      }
    ]
  }
  